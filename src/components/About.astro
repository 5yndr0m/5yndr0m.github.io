---
const experience = [
    {
        title: "TryHackMe: Advent of Cyber 2025",
        detail: "Gained hands-on experience in SIEM (Splunk), malware analysis, and vulnerability assessments.",
    },
    {
        title: "Home Lab Automation",
        detail: "Engineered and maintained secure infrastructure on Linux (Arch/Fedora/CentOS) using container orchestration (Podman/Docker) and Cloudflare Tunnels.",
    },
    {
        title: "Disaster Watch (Team Lead)",
        detail: "Led an 8-person team to develop a MERN-stack community-driven disaster reporting system.",
    },
];

const certifications = [
    {
        title: "TryHackMe: Pre-Security Learning Path",
        detail: "Foundational cybersecurity pathways completed in 2026.",
        link: "https://tryhackme.com/p/5yndr0m",
    },
    {
        title: "TryHackMe: Advent of Cyber 2025",
        detail: "Completed a 24-day intensive cybersecurity challenge.",
        link: "https://tryhackme.com/p/5yndr0m",
    },
    {
        title: "Cisco: Introduction to Cybersecurity",
        detail: "Certified in 2024 via Cisco Networking Academy.",
        link: "",
    },
    {
        title: "MongoDB: Data Modeling Path",
        detail: "Specialized in NoSQL database architecture and modeling.",
        link: "",
    },
];
---

<section
    id="about"
    class="py-24 border-t border-gray-100 dark:border-gray-900 bg-white dark:bg-gray-950"
>
    <div class="max-w-5xl mx-auto px-6">
        <div class="grid md:grid-cols-2 gap-16 items-start">
            <div class="space-y-8">
                <h2 class="text-3xl font-bold text-gray-900 dark:text-white">
                    Who Am I?
                </h2>
                <div
                    class="space-y-6 text-gray-500 dark:text-gray-400 leading-relaxed"
                >
                    <p>
                        I am <span
                            class="text-gray-900 dark:text-white font-semibold"
                            >Senal Dilanjana</span
                        >, a Linux-Native Technologist and IT undergraduate at
                        the University of Vavuniya. I focus on securing digital
                        infrastructures and optimizing system workflows.
                    </p>
                    <p>
                        My daily driver is Arch Linux, and I spend my time
                        engineering secure, self-hosted automation
                        infrastructures and testing them. I am deeply interested
                        in security auditing, ethical hacking, and agentic AI
                        workflows.
                    </p>
                    <p>
                        Outside of the terminal, I enjoy exploring Linux
                        customization and staying updated on CI/CD pipelines. I
                        value collaboration and have experience leading
                        development teams in university and independent
                        environments.
                    </p>
                </div>
            </div>

            <div class="space-y-12">
                <div class="space-y-5">
                    <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-widest">
                        Experience
                    </h3>
                    <ul class="space-y-6">
                        {
                            experience.map((item) => (
                                <li class="space-y-1">
                                    <p class="text-sm font-medium text-gray-900 dark:text-white">
                                        {item.title}
                                    </p>
                                    <p class="text-xs text-gray-500 dark:text-gray-400 leading-relaxed">
                                        {item.detail}
                                    </p>
                                </li>
                            ))
                        }
                    </ul>
                </div>

                <div class="space-y-5">
                    <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-widest">
                        Certifications
                    </h3>
                    <ul class="space-y-6">
                        {
                            certifications.map((item) => (
                                <li class="space-y-1">
                                    <p class="text-sm font-medium text-gray-900 dark:text-white">
                                        {item.title}
                                    </p>
                                    <p class="text-xs text-gray-500 dark:text-gray-400 leading-relaxed">
                                        {item.detail}
                                    </p>
                                    {item.link && (
                                        <a
                                            href={item.link}
                                            target="_blank"
                                            rel="noopener noreferrer"
                                            class="text-xs text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 transition-colors"
                                        >
                                            View certificate →
                                        </a>
                                    )}
                                </li>
                            ))
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>
