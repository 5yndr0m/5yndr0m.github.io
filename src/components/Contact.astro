---
import { Icon } from "astro-icon/components";

const socialLinks = [
    {
        name: "LinkedIn",
        icon: "mdi:linkedin",
        href: "https://linkedin.com/in/senalkad",
        username: "in/senalkad",
    },
    {
        name: "GitHub",
        icon: "mdi:github",
        href: "https://github.com/5yndr0m",
        username: "github/5yndr0m",
    },
    {
        name: "Twitter / X",
        icon: "mdi:twitter",
        href: "https://x.com/Syndromsdk",
        username: "@Syndromsdk",
    },
    {
        name: "Email",
        icon: "mdi:email",
        href: "mailto:contact@dilanjana.me",
        username: "contact@dilanjana.me",
    },
];

const faqs = [
    {
        q: "Are you available for work opportunities?",
        a: "Yes! I am actively seeking roles focusing on Cybersecurity, System Administration, or DevOps where I can apply my expertise in Linux-native environments.",
    },
    {
        q: "What is your typical response time?",
        a: "I usually respond within 24–48 hours. For urgent matters, LinkedIn DM is the fastest way to reach me.",
    },
    {
        q: "Do you handle freelance projects?",
        a: "I take on select freelance work involving Linux server setup, workflow automation (n8n), and full-stack web development.",
    },
    {
        q: "Can we collaborate on open source?",
        a: "Absolutely. I am passionate about the Linux ecosystem. If you have an interesting project on GitHub, let's talk.",
    },
    {
        q: "Are you open to on-site work?",
        a: "I am primarily based in Sri Lanka and open to hybrid/on-site roles within the region, or fully remote global opportunities.",
    },
];
---

<section
    id="contact"
    class="py-24 border-t border-gray-100 dark:border-gray-900 bg-white dark:bg-gray-950"
>
    <div class="max-w-5xl mx-auto px-6">
        <div class="grid md:grid-cols-2 gap-20">
            <div class="space-y-10">
                <div>
                    <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">
                        Let's Collaborate
                    </h2>
                    <p class="text-gray-500 dark:text-gray-400 leading-relaxed text-sm">
                        Whether you're looking to hire for a professional role,
                        start a project, or just discuss the future of AI and
                        Linux—I'm always down to chat.
                    </p>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                    {
                        socialLinks.map((link) => (
                            <a
                                href={link.href}
                                target="_blank"
                                class="flex items-center gap-3 p-4 rounded-lg border border-gray-200 dark:border-gray-800 hover:border-gray-300 dark:hover:border-gray-700 transition-colors group"
                            >
                                <Icon
                                    name={link.icon}
                                    class="w-5 h-5 text-gray-400"
                                />
                                <div>
                                    <p class="text-xs font-medium text-gray-900 dark:text-white">
                                        {link.name}
                                    </p>
                                    <p class="text-xs text-gray-400 mt-0.5">
                                        {link.username}
                                    </p>
                                </div>
                            </a>
                        ))
                    }
                </div>

                <p class="text-xs text-gray-400">
                    Responding within 48 hours · Open to remote collaboration
                </p>
            </div>

            <div class="space-y-6">
                <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-widest">
                    FAQ
                </h3>

                <div class="space-y-1">
                    {
                        faqs.map((faq) => (
                            <details class="group border-b border-gray-100 dark:border-gray-800 last:border-0">
                                <summary class="list-none cursor-pointer flex justify-between items-center text-sm font-medium text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white transition-colors py-3 gap-4">
                                    <span>{faq.q}</span>
                                    <Icon
                                        name="mdi:plus"
                                        class="w-4 h-4 text-gray-400 shrink-0 group-open:rotate-45 transition-transform"
                                    />
                                </summary>
                                <div class="pb-4">
                                    <p class="text-xs text-gray-500 dark:text-gray-400 leading-relaxed">
                                        {faq.a}
                                    </p>
                                </div>
                            </details>
                        ))
                    }
                </div>
            </div>
        </div>
    </div>
</section>
