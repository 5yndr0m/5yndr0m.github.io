---
import { Icon } from "astro-icon/components";
const currentYear = new Date().getFullYear();
---

<footer
    class="border-t border-gray-100 dark:border-gray-900 bg-white dark:bg-gray-950 py-10"
>
    <div class="max-w-5xl mx-auto px-6 flex items-center justify-between">
        <p class="text-xs text-gray-400">
            &copy; {currentYear} Senal Dilanjana
        </p>

        <div class="flex items-center gap-6">
            <a
                href="https://github.com/5yndr0m"
                target="_blank"
                class="text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 transition-colors"
                aria-label="GitHub"
            >
                <Icon name="mdi:github" class="w-4 h-4" />
            </a>
            <a
                href="https://linkedin.com/in/senalkad"
                target="_blank"
                class="text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 transition-colors"
                aria-label="LinkedIn"
            >
                <Icon name="mdi:linkedin" class="w-4 h-4" />
            </a>
            <a
                href="mailto:contact@dilanjana.me"
                class="text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 transition-colors"
                aria-label="Email"
            >
                <Icon name="mdi:email" class="w-4 h-4" />
            </a>
        </div>
    </div>
</footer>
