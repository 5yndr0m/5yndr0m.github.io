---
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import pfpImage from "../assets/pfp.jpeg";
---

<section
    class="min-h-screen flex items-center justify-center bg-white dark:bg-gray-950 px-6 pt-16"
>
    <div class="flex flex-col items-center text-center max-w-3xl">
        <div class="mb-10">
            <Image
                src={pfpImage}
                alt="Senal Dilanjana"
                width={160}
                height={160}
                loading="eager"
                class="w-32 h-32 md:w-40 md:h-40 rounded-full object-cover border border-gray-200 dark:border-gray-800"
            />
        </div>

        <h1
            class="text-3xl md:text-5xl font-bold tracking-tight text-gray-900 dark:text-white leading-tight"
        >
            Linux-Native Technologist
            & <br />
            Cybersecurity Enthusiast.
        </h1>

        <p
            class="mt-6 text-lg text-gray-500 dark:text-gray-400 max-w-xl leading-relaxed"
        >
            Hi, I'm <span class="text-gray-900 dark:text-white font-medium"
                >Senal Dilanjana</span
            >. I secure digital infrastructures and analyze network threats
            using SIEM tools like
            <span
                class="text-gray-900 dark:text-white font-medium"
                >Splunk</span
            >.
        </p>

        <div class="mt-10 flex gap-8">
            {
                [
                    {
                        name: "mdi:github",
                        url: "https://github.com/5yndrom",
                        label: "GitHub",
                    },
                    {
                        name: "mdi:linkedin",
                        url: "https://www.linkedin.com/in/senalkad",
                        label: "LinkedIn",
                    },
                    {
                        name: "mdi:email",
                        url: "mailto:contact@dilanjana.me",
                        label: "Email",
                    },
                ].map((social) => (
                    <a
                        href={social.url}
                        aria-label={social.label}
                        class="text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 transition-colors"
                        target="_blank"
                    >
                        <Icon name={social.name} class="w-6 h-6" />
                    </a>
                ))
            }
        </div>
    </div>
</section>
