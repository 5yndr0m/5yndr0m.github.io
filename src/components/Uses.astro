---
const gear = [
    {
        category: "Hardware Setup",
        description: "Devices and peripherals that power my workspace.",
        items: [
            { model: "HP EliteBook 830 G3", detail: "Main workstation" },
            { model: "Dell IN1910N", detail: "Secondary display" },
            { model: "Jedel GM1320", detail: "Mouse" },
            { model: "Abko AN05", detail: "Keyboard" },
            {
                model: "Samsung Galaxy F05 (RisingOS)",
                detail: "Daily driver smartphone",
            },
        ],
    },
    {
        category: "Development Environment",
        description: "Core tools and configurations for my dev setup.",
        items: [
            {
                model: "Arch Linux (Hyprland + Quickshell)",
                detail: "Lightweight and minimal rolling release",
            },
            {
                model: "Fedora & CentOS",
                detail: "Enterprise-grade environments and server testing",
            },
            {
                model: "Fish Shell",
                detail: "Intuitive shell with smart completions",
            },
            {
                model: "Starship",
                detail: "Fast, cross-shell customizable prompt",
            },
            { model: "Zed & Neovim", detail: "High-performance code editing" },
            {
                model: "Wireshark & Burp Suite",
                detail: "Network analysis and web security auditing",
            },
        ],
    },
    {
        category: "Software & Services",
        description: "Applications I rely on for productivity and security.",
        items: [
            {
                model: "Zen Browser",
                detail: "Primary privacy-focused web navigator",
            },
            {
                model: "Obsidian",
                detail: "Second brain: note-taking and knowledge management",
            },
            {
                model: "Telegram & Discord",
                detail: "Community engagement and secure communication",
            },
            {
                model: "YouTube Music",
                detail: "Workplace focus and entertainment",
            },
        ],
    },
    {
        category: "Tech Stack",
        description: "Languages and technologies I use to build and deploy.",
        items: [
            {
                model: "Python, JavaScript, Bash",
                detail: "System automation and core scripting",
            },
            {
                model: "MERN Stack, Next.js, Astro",
                detail: "Modern full-stack web development",
            },
            {
                model: "Tailwind CSS, Flask, Docker",
                detail: "UI design, micro-frameworks, and containerization",
            },
            {
                model: "MongoDB, MySQL, Cloudflare",
                detail: "Data persistence and edge infrastructure",
            },
        ],
    },
];
---

<section
    id="uses"
    class="py-24 border-t border-gray-100 dark:border-gray-900 bg-white dark:bg-gray-950"
>
    <div class="max-w-5xl mx-auto px-6">
        <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-16">
            Uses
        </h2>

        <div class="space-y-16">
            {
                gear.map((group) => (
                    <div class="grid md:grid-cols-3 gap-10 border-t border-gray-100 dark:border-gray-900/50 pt-12">
                        <div class="md:col-span-1">
                            <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-3">
                                {group.category}
                            </h3>
                            <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed">
                                {group.description}
                            </p>
                        </div>

                        <div class="md:col-span-2">
                            <ul class="grid sm:grid-cols-2 gap-x-8 gap-y-8">
                                {group.items.map((item) => (
                                    <li class="group">
                                        <div class="flex flex-col gap-1.5">
                                            <span class="text-gray-900 dark:text-white font-medium text-sm">
                                                {item.model}
                                            </span>
                                            {item.detail && (
                                                <span class="text-xs text-gray-400 dark:text-gray-500 leading-tight">
                                                    {item.detail}
                                                </span>
                                            )}
                                        </div>
                                    </li>
                                ))}
                            </ul>
                        </div>
                    </div>
                ))
            }
        </div>

        <p class="mt-16 text-xs text-gray-400">
            Last updated {
                new Date().toLocaleDateString("en-US", {
                    month: "long",
                    year: "numeric",
                })
            }
        </p>
    </div>
</section>
